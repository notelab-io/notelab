DATABASE_URL=postgres://YOUR_LOCAL_POSTGRES_USER:YOUR_LOCAL_POSTGRES_PASSWORD@localhost:5432/notelab
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://YOUR_LOCAL_POSTGRES_USER:YOUR_LOCAL_POSTGRES_PASSWORD@localhost:5432/notelab
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
CLIENT_URL=http://localhost:1420,http://localhost:4173
# Optional; defaults to BETTER_AUTH_SECRET when omitted.
COLLABORATION_SECRET=
COLLABORATION_WEBSOCKET_URL=ws://localhost:3000/collaboration
# Optional for alternate dev ports:
# CLIENT_URL=http://localhost:1420,http://localhost:4173,http://localhost:1422

# Optional integration OAuth apps
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
OAUTH_STATE_SECRET=

# Image uploads
# Use "s3" locally to exercise real Cloudflare R2 S3-compatible presigned URLs.
# Use "binding" to store images through Wrangler's local R2 binding instead.
IMAGE_STORAGE_MODE=s3
OPENAI_API_KEY=
IMAGE_UPLOAD_MAX_BYTES=10485760
IMAGE_UPLOAD_URL_TTL_SECONDS=600
IMAGE_READ_URL_TTL_SECONDS=300
R2_ACCOUNT_ID=
R2_BUCKET_NAME=notelab-images
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional override. Defaults to https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=
