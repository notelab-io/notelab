{
  "name": "@notelab/server",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --port 3000",
    "build": "tsc --noEmit",
    "test:insert-database-block": "tsx --test src/services/insert-database-block.test.ts",
    "test:database-property-config": "tsx --test src/services/database-property-config.test.ts",
    "test:database-delta": "tsx --test src/services/database-delta.test.ts",
    "test:databases": "tsx --test src/services/database-property-config.test.ts src/services/database-delta.test.ts src/services/insert-database-block.test.ts",
    "test:api-keys": "tsx src/scripts/test-api-key-flow.ts",
    "test:flow": "tsx src/scripts/simulate-user-flow.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node src/scripts/prod-db-migrate.mjs migrate",
    "db:reset": "tsx src/scripts/reset-database.ts && drizzle-kit migrate",
    "db:reset:prod": "node src/scripts/prod-db-migrate.mjs reset --confirm-production-reset",
    "db:status:prod": "node src/scripts/prod-db-migrate.mjs status",
    "db:studio": "drizzle-kit studio",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.6.0",
    "agents": "^0.12.1",
    "@ai-sdk/openai": "^3.0.72",
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@better-auth/api-key": "^1.6.14",
    "@better-auth/drizzle-adapter": "^1.6.14",
    "@better-auth/expo": "^1.6.14",
    "@notelab/connectors": "file:../../packages/connectors",
    "ai": "^6.0.193",
    "better-auth": "^1.6.14",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.4.0"
  },
  "private": true
}
