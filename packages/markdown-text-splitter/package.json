{
  "name": "markdown-text-splitter",
  "version": "0.1.0",
  "description": "Standalone markdown text splitters inspired by LangChain's markdown splitters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "demo": "npm run build && node dist/demo.js"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "keywords": [
    "markdown",
    "splitter",
    "text-splitter",
    "langchain"
  ],
  "license": "MIT"
}
